# Copia este archivo como .env y completa los valores reales
# cp .env.example .env

# Token del bot de Telegram (obtenido con @BotFather)
TELEGRAM_BOT_TOKEN=

# Credenciales del portal UNMSM (WebSum)
WEB_USER=
WEB_PASS=

# Índices 0-base de los <select> en la página de emisión de tickets
# El índice 0 siempre es "Seleccione…"; estos valores son los predeterminados
SEDE_IDX=1
SERVICIO_IDX=2

# Número máximo de sesiones de Playwright en simultáneo
MAX_CONCURRENT=2

# true = navegador invisible (producción), false = navegador visible (depuración)
HEADLESS=true
